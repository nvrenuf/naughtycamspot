---
import MainLayout from '../../layouts/MainLayout.astro';
import SEO from '../../components/SEO.astro';
import { withBase } from '../../utils/links';

const destination = `${withBase('/apply')}${Astro.url.search}`;
---

<MainLayout title="Apply | NaughtyCamSpot" description="This route now uses the unified apply flow.">
  <SEO slot="head" title="Apply | NaughtyCamSpot" description="This route now uses the unified apply flow." path="/apply" />
  <meta http-equiv="refresh" content={`0;url=${destination}`} />

  <section class="content-card space-y-4">
    <p class="hero-tagline">Apply</p>
    <h1 class="font-display text-4xl text-white sm:text-5xl">Use the unified apply form.</h1>
    <p class="max-w-2xl text-base text-white/75">This page moved to one short intake flow.</p>
    <a
      class="inline-flex items-center justify-center rounded-full border border-rose-gold/70 bg-rose-gold px-6 py-3 text-sm uppercase tracking-[0.3em] text-midnight"
      href={destination}
    >
      Continue to apply
    </a>
  </section>
</MainLayout>
