---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { PLATFORMS } from '../data/platforms';
import { withBase } from '../utils/links';

const canonicalPath = '/apply';
const contactMethods = ['Telegram', 'Email', 'WhatsApp'] as const;
---

<MainLayout
  title="Apply | NaughtyCamSpot"
  description="Apply for signup guidance and launch-start support. Models who sign up through NCS get the Model Launch Kit free."
>
  <SEO
    slot="head"
    title="Apply | NaughtyCamSpot"
    description="Apply for signup guidance and launch-start support. Models who sign up through NCS get the Model Launch Kit free."
    path={canonicalPath}
  />

  <section class="hero-shell hero-split parallax-veil">
    <div class="hero-content">
      <p class="eyebrow">Signup-first application</p>
      <h1 class="hero-title">Apply to <em>start signup correctly</em>.</h1>
      <p class="hero-sub">
        This form is for signup guidance and launch-start support. Models who sign up through NCS get the Model Launch Kit free. The
        same kit is also available separately for $200 USD, and the name branding app is available even before applying.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-secondary" href={withBase('/name-check/')}>Check Your Model Name</a>
        <a class="btn btn-secondary" href={withBase('/launch-kit/')}>View Model Launch Kit</a>
      </div>
    </div>
    <div class="hero-media">
      <img src="/images/home-hero-768.jpg" alt="Editorial intake visual for signup-first launch support" loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="content-card space-y-4">
    <p class="eyebrow">Application form</p>
    <h2 class="font-display text-4xl font-light text-parchment">Tell us enough to guide your launch start.</h2>
    <p class="max-w-3xl text-sm text-parchment/70">
      We use this form to understand your starting point, your preferred model name, and which platforms you want to begin with. This
      is not a public growth-ladder intake.
    </p>
    <form class="grid gap-3 md:grid-cols-2" method="post" action={withBase('/claim/index.php')}>
      <input type="hidden" name="source_page" value="/apply/" />
      <input class="border border-gold/25 bg-midnight px-4 py-3 text-sm" type="text" name="preferred_model_name" placeholder="Preferred model name" required />
      <input class="border border-gold/25 bg-midnight px-4 py-3 text-sm" type="text" name="alternate_model_names" placeholder="Alternate model names, if any" />
      <select class="border border-gold/25 bg-midnight px-4 py-3 text-sm" name="current_stage" required>
        <option value="">Current stage</option>
        <option value="new">New and preparing to start</option>
        <option value="launching">Launching now</option>
        <option value="relaunching">Relaunching with a new brand direction</option>
        <option value="active">Already active but fixing setup consistency</option>
      </select>
      <select class="border border-gold/25 bg-midnight px-4 py-3 text-sm" name="platform_interest" required>
        <option value="">Platform interest</option>
        {PLATFORMS.map((platform) => <option value={platform.id}>{platform.name}</option>)}
      </select>
      <input class="border border-gold/25 bg-midnight px-4 py-3 text-sm" type="text" name="current_platforms" placeholder="Current platforms, if any" />
      <input class="border border-gold/25 bg-midnight px-4 py-3 text-sm" type="text" name="current_handles" placeholder="Current handles/usernames, if any" />
      <select class="border border-gold/25 bg-midnight px-4 py-3 text-sm" name="preferred_contact_method" required>
        <option value="">Preferred contact method</option>
        {contactMethods.map((method) => <option value={method.toLowerCase()}>{method}</option>)}
      </select>
      <input class="border border-gold/25 bg-midnight px-4 py-3 text-sm" type="text" name="contact" placeholder="Contact (Telegram, email, or WhatsApp)" required />
      <textarea class="border border-gold/25 bg-midnight px-4 py-3 text-sm md:col-span-2" name="notes" rows="4" placeholder="Notes about your model name, platform interests, launch stage, or questions." />
      <label class="flex items-start gap-3 text-sm text-parchment/72 md:col-span-2">
        <input type="checkbox" name="consent_18_plus" value="yes" required class="mt-1" />
        <span>I confirm I am 18+ and I consent to submit this application for signup guidance and launch-start support.</span>
      </label>
      <label class="flex items-start gap-3 text-sm text-parchment/72 md:col-span-2">
        <input type="checkbox" name="consent_updates" value="yes" class="mt-1" />
        <span>Optional: I consent to receive follow-up updates from NaughtyCamSpot.</span>
      </label>
      <div class="space-y-3 md:col-span-2">
        <button class="btn btn-primary w-full sm:w-auto" type="submit">Apply / Start Signup</button>
        <p class="text-sm text-parchment/62">No passwords. No exclusivity. You keep ownership of your accounts and content.</p>
      </div>
    </form>
  </section>

  <TrustRulesBlock title="Trust stays visible before submission" />
</MainLayout>
