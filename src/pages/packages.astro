---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/packages';

const launchKitIncludes = [
  'Platform selection guidance for where to start',
  'Model name and brand planning before signup',
  'Profile setup checklist for a cleaner first impression',
  'Launch readiness checklist before going live',
  'Beginner mistake avoidance notes',
  'Basic room, menu, and goal structure guidance',
  'Trust and account ownership basics'
];
---

<MainLayout
  title="Packages | NaughtyCamSpot"
  description="The public package is the Model Launch Kit: free with NCS signup or available separately for $200 USD."
>
  <SEO
    slot="head"
    title="Packages | NaughtyCamSpot"
    description="The public package is the Model Launch Kit: free with NCS signup or available separately for $200 USD."
    path={canonicalPath}
  />

  <section class="hero-shell hero-split parallax-veil">
    <div class="hero-content">
      <p class="eyebrow">Public package</p>
      <h1 class="hero-title">The public offer is the <em>Model Launch Kit</em>.</h1>
      <p class="hero-sub">
        NaughtyCamSpot is public-facing as a signup-first launch service. Sign up through NCS and get the Model Launch Kit free, or buy
        the same package separately for $200 USD if you do not want to use an NCS signup path.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={withBase('/apply/')}>Apply / Start Signup</a>
        <a class="btn btn-secondary" href={withBase('/launch-kit/')}>View Launch Kit</a>
      </div>
    </div>
    <div class="hero-media">
      <img src="/images/home-hero-1280.jpg" alt="Editorial Model Launch Kit visual" loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="content-card space-y-5">
    <p class="eyebrow">Price and access</p>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h2 class="font-display text-3xl text-parchment">Free with signup</h2>
        <p class="mt-2">Models who sign up through NCS can receive the Model Launch Kit free as part of the signup-first onboarding path.</p>
      </article>
      <article class="bg-obsidian p-5 text-sm text-parchment/74">
        <h2 class="font-display text-3xl text-parchment">$200 USD standalone</h2>
        <p class="mt-2">Models who do not sign up through NCS can still buy the Model Launch Kit as a standalone package for $200 USD.</p>
      </article>
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h2 class="font-display text-3xl text-parchment">For new or restarting models</h2>
        <p class="mt-2">This package is built for new models, relaunches, and anyone who wants a cleaner start before trying to scale.</p>
      </article>
    </div>
  </section>

  <section class="content-card space-y-5">
    <p class="eyebrow">What the kit helps with</p>
    <div class="grid gap-4 md:grid-cols-2">
      <article class="premium-card">
        <ul class="space-y-2 text-sm text-parchment/74">
          {launchKitIncludes.slice(0, 4).map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="premium-card">
        <ul class="space-y-2 text-sm text-parchment/74">
          {launchKitIncludes.slice(4).map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="content-card space-y-4">
    <p class="eyebrow">What this package does not promise</p>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <p class="bg-midnight p-5 text-sm text-parchment/74">No guaranteed earnings. The package is about starting correctly, not promising a money outcome.</p>
      <p class="bg-obsidian p-5 text-sm text-parchment/74">No official partner claim unless explicitly confirmed elsewhere. This page does not assume platform partnership.</p>
      <p class="bg-midnight p-5 text-sm text-parchment/74">No promise of promotion as part of the Model Launch Kit. Public emphasis stays on signup and launch readiness.</p>
    </div>
  </section>

  <TrustRulesBlock title="Trust rules stay fixed around the Model Launch Kit" />

  <section class="content-card space-y-4">
    <h2 class="font-display text-4xl font-light text-parchment">Broader support is not the main public offer.</h2>
    <p class="text-sm text-parchment/72">
      Future or selected-model support may exist later, but this page intentionally keeps the public package simple. The clear public
      paid offer is the Model Launch Kit.
    </p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/apply/')}>Apply / Start Signup</a>
      <a class="btn btn-secondary" href={withBase('/name-check/')}>Check Your Model Name</a>
    </div>
  </section>
</MainLayout>
