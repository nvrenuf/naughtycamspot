---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/';
---

<MainLayout
  title="NaughtyCamSpot | Start your cam model brand the right way"
  description="Choose your platform path, pre-check your model name for brand consistency, and start with clean signup guidance."
>
  <SEO
    slot="head"
    title="NaughtyCamSpot | Start your cam model brand the right way"
    description="Choose your platform path, pre-check your model name for brand consistency, and start with clean signup guidance."
    path={canonicalPath}
  />

  <section class="hero-shell hero-split parallax-veil" id="signup-first-hero">
    <div class="hero-content">
      <p class="eyebrow">Signup-first guidance</p>
      <h1 class="hero-title">Start your cam model brand <em>the right way</em>.</h1>
      <p class="hero-sub">
        Before you sign up everywhere, make sure your model name can become a real brand across cam sites, socials, and your fan hub.
        NaughtyCamSpot helps you choose the right platform path, pressure-test your name, and apply with clean launch readiness.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={withBase('/apply/')}>Apply for Signup Guidance</a>
        <a class="btn btn-secondary" href={withBase('/name-check/')}>Check Your Model Name</a>
      </div>
    </div>
    <figure class="hero-media">
      <img src="/images/home-hero.webp" alt="Editorial portrait for NaughtyCamSpot launch guidance" loading="eager" decoding="async" />
      <figcaption class="absolute bottom-6 left-6 z-10 border-l border-gold/50 pl-4 text-left text-xs uppercase tracking-[0.18em] text-gold/85">
        Premium launch posture • practical signup-first execution
      </figcaption>
    </figure>
  </section>

  <TrustRulesBlock title="Non-negotiable trust rules" />

  <section class="content-card space-y-5">
    <p class="eyebrow">What we help with first</p>
    <h2 class="font-display text-4xl font-light text-parchment">Clean setup before noisy promotion.</h2>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Platform fit</h3>
        <p class="mt-2">Choose signup paths that match your stage and content style instead of guessing across too many platforms.</p>
      </article>
      <article class="bg-obsidian p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Model-name brandability</h3>
        <p class="mt-2">Check whether your name can stay consistent across cam handles, socials, and domain-style branding.</p>
      </article>
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Launch readiness</h3>
        <p class="mt-2">Apply once and get guidance focused on a durable start: naming, signup path, and account consistency.</p>
      </article>
    </div>
  </section>

  <section class="content-card space-y-4" id="final-cta">
    <h2 class="font-display text-4xl font-light text-parchment">Start with the right name and signup path.</h2>
    <p class="max-w-3xl text-sm text-parchment/70">
      Public focus is startup clarity for new and relaunching models. Selected growth support may be available later, but it is not the
      main product on this site.
    </p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/apply/')}>Apply</a>
      <a class="btn btn-secondary" href={withBase('/name-check/')}>Name Check</a>
    </div>
  </section>
</MainLayout>
