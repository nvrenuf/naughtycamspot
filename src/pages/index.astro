---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/';
---

<MainLayout title="NaughtyCamSpot | Growth systems for active cam talent" description="Growth-first support for active cam models plus a guided launch lane using Professional Onboarding Tools.">
  <SEO slot="head" title="NaughtyCamSpot | Growth systems for active cam talent" description="Growth-first support for active cam models plus a guided launch lane using Professional Onboarding Tools." path={canonicalPath} />

  <section class="hero-shell hero-split parallax-veil" id="growth-first-hero">
    <div class="hero-content">
      <p class="eyebrow">Growth-First Public Site</p>
      <h1 class="hero-title">We build <em>revenue systems</em> for active cam models.</h1>
      <p class="hero-sub">
        NaughtyCamSpot leads with premium growth for active models: stronger traffic flow, tighter conversion structure, higher VIP retention,
        and better passive-income consistency. New models still have a guided launch lane, but growth remains the public center of gravity.
      </p>
      <p class="mt-4 font-display text-xl italic text-parchment/40">Professional systems. Control stays with the model.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={withBase('/growth/')}>Explore Growth</a>
        <a class="btn btn-secondary" href={withBase('/apply/')}>Apply</a>
      </div>
    </div>
    <figure class="hero-media">
      <img src="/images/home-hero.webp" alt="Editorial growth-focused model portrait" loading="eager" decoding="async" />
      <figcaption class="absolute bottom-6 left-6 z-10 border-l border-gold/50 pl-4 text-left text-xs uppercase tracking-[0.18em] text-gold/85">Featured visual presence • replaceable VIP styling</figcaption>
    </figure>
  </section>

  <TrustRulesBlock title="Non-negotiable trust rules" />

  <section class="content-card space-y-8" id="what-we-actually-are">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="space-y-4">
        <p class="eyebrow">What we actually are</p>
        <h2 class="section-heading">A premium growth business, not a "done-for-you" account takeover.</h2>
        <p class="text-sm leading-8 text-parchment/72">NCS is an operator-led growth partner for active models. We structure revenue systems and execution rhythm; we do not ask for passwords, control accounts, or promise fantasy outcomes.</p>
      </div>
      <div class="space-y-px bg-gold/20">
        <div class="bg-midnight p-5"><p class="eyebrow text-parchment/40">Not this</p><p class="text-sm text-parchment/38 line-through decoration-white/20">Generic agency hype, spam tactics, fake "official partner" claims.</p></div>
        <div class="bg-obsidian p-5"><p class="eyebrow">This</p><p class="text-sm text-parchment/75">Structured growth systems, transparent rules, and model-owned assets.</p></div>
      </div>
    </div>
  </section>

  <section class="space-y-6" id="four-pillar-revenue-system">
    <div class="section-intro">
      <p class="eyebrow">Four pillars</p>
      <h2 class="section-heading">Four-pillar revenue system for premium growth execution.</h2>
    </div>
    <div class="pill-grid">
      <article class="pill-item"><p class="font-display text-5xl text-gold/25">01</p><h3 class="mt-2 font-display text-3xl text-parchment">Traffic</h3><p class="mt-2 text-sm text-parchment/65">Placeholder channel planning for platform-aware traffic and audience routing.</p></article>
      <article class="pill-item"><p class="font-display text-5xl text-gold/25">02</p><h3 class="mt-2 font-display text-3xl text-parchment">Room Conversion</h3><p class="mt-2 text-sm text-parchment/65">Placeholder room systems for menu architecture and conversion checkpoints.</p></article>
      <article class="pill-item"><p class="font-display text-5xl text-gold/25">03</p><h3 class="mt-2 font-display text-3xl text-parchment">VIP Retention</h3><p class="mt-2 text-sm text-parchment/65">Placeholder retention ladders and follow-up continuity.</p></article>
      <article class="pill-item"><p class="font-display text-5xl text-gold/25">04</p><h3 class="mt-2 font-display text-3xl text-parchment">Passive Income</h3><p class="mt-2 text-sm text-parchment/65">Placeholder evergreen monetization support off-stream.</p></article>
    </div>
  </section>

  <section class="grid gap-5 lg:grid-cols-2" id="two-path-split">
    <article class="split-choice space-y-3">
      <p class="eyebrow">Path 1</p>
      <h2 class="font-display text-4xl font-light text-parchment">Already modeling?</h2>
      <p class="text-sm text-parchment/70">Go straight into the Growth lane for diagnosis, package matching, and active optimization.</p>
      <a class="btn btn-secondary" href={withBase('/growth/')}>Explore Growth</a>
    </article>
    <article class="split-choice space-y-3">
      <p class="eyebrow">Path 2</p>
      <h2 class="font-display text-4xl font-light text-parchment">New to modeling?</h2>
      <p class="text-sm text-parchment/70">Use Professional Onboarding Tools first, then unlock Start Right only after routed signup completion.</p>
      <a class="btn btn-secondary" href={withBase('/apply/')}>Use Onboarding Tools</a>
    </article>
  </section>

  <section class="content-card space-y-5" id="conservative-proof-preview">
    <p class="eyebrow">Proof preview</p>
    <h2 class="font-display text-4xl font-light text-parchment">Conservative proof posture with a light VIP cameo.</h2>
    <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
      <p class="text-sm text-parchment/70">Public proof remains sample/template based only: workflows, deliverable examples, and system snapshots. No fake claims and no unsupported earnings storytelling.</p>
      <div class="premium-card">
        <p class="eyebrow">Featured VIP (replaceable)</p>
        <p class="mt-2 text-sm text-parchment/75"><strong class="text-parchment">Anna</strong> appears as supporting presence only, never as the central business proposition.</p>
      </div>
    </div>
    <a class="btn btn-secondary" href={withBase('/proof/')}>View Proof</a>
  </section>

  <section class="content-card space-y-5" id="growth-package-preview">
    <p class="eyebrow">Growth package preview</p>
    <h2 class="font-display text-4xl font-light text-parchment">Selective package framing, not startup pricing tiles.</h2>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="bg-midnight p-5 text-sm text-parchment/72"><h3 class="font-display text-3xl text-parchment">[Growth Package Placeholder A]</h3><p class="mt-2">Foundation optimization and reporting rhythm.</p></article>
      <article class="bg-obsidian p-5 text-sm text-parchment/72"><h3 class="font-display text-3xl text-parchment">[Growth Package Placeholder B]</h3><p class="mt-2">Expanded campaign testing and retention systems.</p></article>
      <article class="bg-midnight p-5 text-sm text-parchment/72"><h3 class="font-display text-3xl text-parchment">[Growth Package Placeholder C]</h3><p class="mt-2">Hands-on strategic execution across all four pillars.</p></article>
    </div>
  </section>

  <section class="content-card space-y-4" id="final-cta">
    <h2 class="font-display text-4xl font-light text-parchment">Pick the lane that matches your stage.</h2>
    <p class="max-w-3xl text-sm text-parchment/70">Active models go to Growth. New models apply for Professional Onboarding Tools first; Start Right remains post-signup only.</p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/growth/')}>I want growth now</a>
      <a class="btn btn-secondary" href={withBase('/apply/')}>I need guided launch help</a>
    </div>
  </section>
</MainLayout>
