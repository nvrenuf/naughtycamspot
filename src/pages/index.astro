---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/';
---

<MainLayout title="NaughtyCamSpot | Growth Systems for Active Cam Models" description="Growth-first support for active cam models plus a guided launch lane using Professional Onboarding Tools.">
  <SEO slot="head" title="NaughtyCamSpot | Growth Systems for Active Cam Models" description="Growth-first support for active cam models plus a guided launch lane using Professional Onboarding Tools." path={canonicalPath} />

  <section class="content-card space-y-5">
    <p class="hero-tagline">Premium Growth Business</p>
    <h1 class="font-display text-4xl text-white sm:text-5xl">Scale your cam revenue with a four-pillar growth system.</h1>
    <p class="max-w-3xl text-white/75">NaughtyCamSpot is built first for active models who want better traffic, higher conversion, stronger VIP retention, and reliable passive income systems. New models can still launch through our guided path.</p>
    <div class="flex flex-wrap gap-3">
      <a class="btn border border-rose-gold/70 bg-rose-gold text-midnight" href={withBase('/growth/')}>View Growth Packages</a>
      <a class="btn btn-secondary" href={withBase('/apply/')}>Apply for Guided Launch</a>
    </div>
  </section>

  <TrustRulesBlock title="Non-negotiable trust rules" />

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Four-pillar revenue system</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4"><h3 class="text-xl text-white">Traffic</h3><p class="text-sm text-white/75">Placeholder: omnichannel traffic plan and platform-specific audience capture.</p></article>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4"><h3 class="text-xl text-white">Room Conversion</h3><p class="text-sm text-white/75">Placeholder: room scripts, pricing psychology, and live conversion checkpoints.</p></article>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4"><h3 class="text-xl text-white">VIP Retention</h3><p class="text-sm text-white/75">Placeholder: VIP lifecycle cadence, messaging templates, and return-visit loops.</p></article>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4"><h3 class="text-xl text-white">Passive Income</h3><p class="text-sm text-white/75">Placeholder: feed/subscription offers, bundles, and evergreen promo workflows.</p></article>
    </div>
  </section>

  <section class="grid gap-5 lg:grid-cols-2">
    <article class="content-card space-y-3">
      <p class="text-xs uppercase tracking-[0.3em] text-rose-petal/70">Path 1</p>
      <h2 class="font-display text-3xl text-white">Already modeling?</h2>
      <p class="text-sm text-white/75">Go straight into the Growth lane with package-led execution.</p>
      <a class="btn btn-secondary" href={withBase('/growth/')}>Explore Growth</a>
    </article>
    <article class="content-card space-y-3">
      <p class="text-xs uppercase tracking-[0.3em] text-rose-petal/70">Path 2</p>
      <h2 class="font-display text-3xl text-white">New to modeling?</h2>
      <p class="text-sm text-white/75">Use Professional Onboarding Tools for a guided start, platform fit, and routed signup help.</p>
      <a class="btn btn-secondary" href={withBase('/apply/')}>Start Guided Launch</a>
    </article>
  </section>

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Growth package preview (placeholder)</h2>
    <div class="grid gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-white/75"><h3 class="text-white">[Package A Placeholder]</h3><p>Placeholder scope for active models with core weekly optimization.</p></article>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-white/75"><h3 class="text-white">[Package B Placeholder]</h3><p>Placeholder scope for deeper campaign systems and retention workflows.</p></article>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-white/75"><h3 class="text-white">[Package C Placeholder]</h3><p>Placeholder scope for premium growth execution and strategic support.</p></article>
    </div>
  </section>

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Proof preview (sample/template posture)</h2>
    <p class="text-sm text-white/75">We show sample workflows and template deliverables only. No fake outcomes and no unsupported metrics.</p>
    <p class="text-sm text-white/75"><strong>Featured VIP cameo:</strong> Anna appears as a replaceable example profile in the proof section.</p>
    <a class="btn btn-secondary" href={withBase('/proof/')}>View Proof</a>
  </section>

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Choose your lane</h2>
    <div class="flex flex-wrap gap-3">
      <a class="btn border border-rose-gold/70 bg-rose-gold text-midnight" href={withBase('/growth/')}>I want growth now</a>
      <a class="btn btn-secondary" href={withBase('/apply/')}>I need guided launch help</a>
    </div>
  </section>
</MainLayout>
