---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/';
---

<MainLayout
  title="NaughtyCamSpot | Sign up through NCS and get the Model Launch Kit free"
  description="NaughtyCamSpot helps new cam models start correctly. Sign up through NCS and get the Model Launch Kit free, or buy it separately for $200 USD."
>
  <SEO
    slot="head"
    title="NaughtyCamSpot | Sign up through NCS and get the Model Launch Kit free"
    description="NaughtyCamSpot helps new cam models start correctly. Sign up through NCS and get the Model Launch Kit free, or buy it separately for $200 USD."
    path={canonicalPath}
  />

  <section class="hero-shell hero-split parallax-veil" id="signup-first-hero">
    <div class="hero-content">
      <p class="eyebrow">Signup-first launch guidance</p>
      <h1 class="hero-title">Sign up through NCS and get the <em>Model Launch Kit free</em>.</h1>
      <p class="hero-sub">
        NaughtyCamSpot helps new cam models start correctly. Before you go live everywhere, choose a brandable name, pick the right
        platform, and get the launch materials that help you avoid beginner mistakes.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={withBase('/apply/')}>Apply / Start Signup</a>
        <a class="btn btn-secondary" href={withBase('/name-check/')}>Check Your Model Name</a>
      </div>
    </div>
    <figure class="hero-media">
      <img src="/images/home-hero.webp" alt="Editorial portrait for NaughtyCamSpot signup-first launch guidance" loading="eager" decoding="async" />
      <figcaption class="absolute bottom-6 left-6 z-10 border-l border-gold/50 pl-4 text-left text-xs uppercase tracking-[0.18em] text-gold/85">
        Premium launch posture • clean signup-first execution
      </figcaption>
    </figure>
  </section>

  <section class="content-card space-y-5">
    <p class="eyebrow">Public offer</p>
    <h2 class="font-display text-4xl font-light text-parchment">Start correctly before you chase traffic.</h2>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Free with NCS signup</h3>
        <p class="mt-2">Sign up through NaughtyCamSpot and get the Model Launch Kit free as part of the guided start.</p>
      </article>
      <article class="bg-obsidian p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">$200 USD standalone</h3>
        <p class="mt-2">If you do not sign up through NCS, the same Model Launch Kit is available as a public standalone package for $200 USD.</p>
      </article>
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Free name check</h3>
        <p class="mt-2">The model name branding app stays public and free for anyone who wants to check brandability before signup.</p>
      </article>
    </div>
  </section>

  <section class="content-card space-y-5">
    <p class="eyebrow">What the launch flow covers</p>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Choose the right platform</h3>
        <p class="mt-2">Use the platform list to avoid starting in the wrong place or scattering attention across too many accounts.</p>
      </article>
      <article class="bg-obsidian p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Pick a brandable name</h3>
        <p class="mt-2">Check whether your model name can stay consistent across cam handles, socials, and future brand assets.</p>
      </article>
      <article class="bg-midnight p-5 text-sm text-parchment/74">
        <h3 class="font-display text-3xl text-parchment">Launch with fewer mistakes</h3>
        <p class="mt-2">The Model Launch Kit focuses on setup, profile readiness, room structure, trust basics, and beginner mistake avoidance.</p>
      </article>
    </div>
  </section>

  <TrustRulesBlock title="Trust rules stay public from the first click" />

  <section class="content-card space-y-4" id="final-cta">
    <h2 class="font-display text-4xl font-light text-parchment">Public focus is signup, launch readiness, and clean setup.</h2>
    <p class="max-w-3xl text-sm text-parchment/70">
      Promotion and broader growth work are not the main public offer in this pass. The public path is simple: check your name, choose
      your platform, and start signup through NCS if you want the Model Launch Kit free.
    </p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/apply/')}>Apply / Start Signup</a>
      <a class="btn btn-secondary" href={withBase('/launch-kit/')}>View Model Launch Kit</a>
    </div>
  </section>
</MainLayout>
