---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';

const canonicalPath = '/proof';
---

<MainLayout title="Proof | NaughtyCamSpot" description="Conservative sample/template proof of systems and deliverables.">
  <SEO slot="head" title="Proof | NaughtyCamSpot" description="Conservative sample/template proof of systems and deliverables." path={canonicalPath} />

  <section class="content-card section-intro">
    <p class="eyebrow">Proof</p>
    <h1 class="section-heading">Sample/template proof, not earnings promises.</h1>
    <p class="text-sm text-parchment/70">Conservative by design: sample workflows, template deliverables, and example system blocks only.</p>
  </section>

  <section class="grid gap-px bg-gold/18 md:grid-cols-2">
    <article class="premium-card"><h2 class="font-display text-3xl text-parchment">Sample workflow template</h2><p class="mt-2 text-sm text-parchment/72">Weekly growth sprint structure with four-pillar checkpoints.</p></article>
    <article class="premium-card"><h2 class="font-display text-3xl text-parchment">Deliverables template</h2><p class="mt-2 text-sm text-parchment/72">Content pack, live script, and retention follow-up template placeholders.</p></article>
    <article class="premium-card"><h2 class="font-display text-3xl text-parchment">Campaign placeholder</h2><p class="mt-2 text-sm text-parchment/72">Campaign brief, channel matrix, and QA checklist format.</p></article>
    <article class="premium-card"><h2 class="font-display text-3xl text-parchment">System placeholder</h2><p class="mt-2 text-sm text-parchment/72">Operating rhythm and decision logs without performance claims.</p></article>
  </section>

  <section class="hero-shell hero-split">
    <div class="hero-content">
      <p class="eyebrow">Featured VIP (replaceable)</p>
      <h2 class="font-display text-5xl font-light text-parchment">Anna cameo block</h2>
      <p class="mt-3 text-sm text-parchment/70">Anna is intentional but lightweight: a supporting proof accent that can be replaced with any future VIP profile.</p>
    </div>
    <div class="hero-media">
      <img src="/images/home-hero.webp" alt="VIP editorial reference visual" loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="content-card">
    <p class="text-sm text-parchment/70">No unsupported metrics, no fake income claims, and no fake “official results” language.</p>
  </section>
</MainLayout>
