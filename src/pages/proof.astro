---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';

const canonicalPath = '/proof';
---

<MainLayout title="Proof | NaughtyCamSpot" description="Conservative sample/template proof of systems and deliverables.">
  <SEO slot="head" title="Proof | NaughtyCamSpot" description="Conservative sample/template proof of systems and deliverables." path={canonicalPath} />

  <section class="hero-shell parallax-veil space-y-4">
    <p class="hero-tagline">Proof</p>
    <h1 class="font-display text-4xl text-white sm:text-5xl">Sample/template proof, not earnings promises.</h1>
    <p class="max-w-3xl text-sm text-white/75">This page stays conservative on purpose: sample workflows, template deliverables, and example content blocks only. No fake metrics and no unsupported earnings proof.</p>
  </section>

  <section class="grid gap-5 md:grid-cols-2">
    <article class="content-card"><h2 class="font-display text-2xl text-white">Sample workflow template</h2><p class="text-sm text-white/75">Placeholder: weekly growth sprint workflow with checkpoints for traffic, room conversion, VIP retention, and passive income.</p></article>
    <article class="content-card"><h2 class="font-display text-2xl text-white">Sample deliverables template</h2><p class="text-sm text-white/75">Placeholder: content pack template, live script template, and retention follow-up template.</p></article>
    <article class="content-card"><h2 class="font-display text-2xl text-white">Example campaign placeholder</h2><p class="text-sm text-white/75">Placeholder: campaign brief, channel matrix, and QA checklist format.</p></article>
    <article class="content-card"><h2 class="font-display text-2xl text-white">Example system placeholder</h2><p class="text-sm text-white/75">Placeholder: growth operating rhythm and decision logs without performance claims.</p></article>
  </section>

  <section class="content-card space-y-3">
    <p class="text-xs uppercase tracking-[0.3em] text-rose-petal/70">Featured VIP (replaceable)</p>
    <h2 class="font-display text-3xl text-white">Anna VIP Block</h2>
    <p class="text-sm text-white/75">Anna is a featured VIP example only. This block is intentionally modular so any future VIP profile can replace it without changing the page architecture.</p>
  </section>

  <section class="content-card">
    <p class="text-sm text-white/70">No unsupported metrics, no fake income claims, and no fake “results” language.</p>
  </section>
</MainLayout>
