---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import LaunchNotice from '../components/LaunchNotice.astro';
import { withBase } from '../utils/links';
import { growthUnlocks, promoLaunch } from '../data/promoLaunch';

const canonicalPath = '/growth';
---

<MainLayout
  title="Growth | Live April 2026"
  description="The next NaughtyCamSpot growth line opens in April 2026. Founding spots and early access are open now."
>
  <SEO
    slot="head"
    title="Growth | Live April 2026"
    description="The next NaughtyCamSpot growth line opens in April 2026. Founding spots and early access are open now."
    path={canonicalPath}
  />

  <section class="hero-shell hero-split parallax-veil space-y-4">
    <div class="hero-content">
      <p class="eyebrow">Growth preview</p>
      <h1 class="hero-title">The next growth line opens <em>in April 2026</em>.</h1>
      <p class="hero-sub">
        This is the teaser page for what is coming next, not a claim that every system is already fully live. Founding spots, early
        access, and launch conversations are open now for models who want in before the public rollout.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href={withBase('/apply/?interest=founding')}>Claim Founding Access</a>
        <a class="btn btn-secondary" href={withBase('/apply/?interest=active-growth')}>Apply for Early Access</a>
      </div>
    </div>
    <div class="hero-media">
      <img src="/images/home-hero-1280.jpg" alt="Luxury editorial preview for the April 2026 growth launch" loading="lazy" decoding="async" />
    </div>
  </section>

  <LaunchNotice
    title="Founding spots are open now."
    body="The new line is for models who want something smarter than generic promo posting. The full direction opens in April 2026."
  />

  <section class="content-card space-y-5">
    <p class="eyebrow">What this is not</p>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <p class="bg-midnight p-5 text-sm text-parchment/75">Not a promise to blast X, Reddit, and generic socials harder.</p>
      <p class="bg-obsidian p-5 text-sm text-parchment/75">Not a cheap package ladder pretending every feature already exists today.</p>
      <p class="bg-midnight p-5 text-sm text-parchment/75">Not a one-room definition of collabs, traffic, or model growth.</p>
    </div>
  </section>

  <section class="space-y-6">
    <div class="section-intro">
      <p class="eyebrow">What models will unlock</p>
      <h2 class="section-heading">A smarter revenue-system approach for the next era of cam growth.</h2>
      <p class="text-sm text-parchment/65">These are the pillars being built now for the April 2026 opening.</p>
    </div>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      {growthUnlocks.map((item, index) => (
        <article class={`premium-card ${index % 2 === 1 ? 'bg-[#100d07]' : ''}`}>
          <p class="eyebrow">{String(index + 1).padStart(2, '0')}</p>
          <h3 class="font-display text-4xl text-parchment">{item.title}</h3>
          <p class="mt-2 text-sm text-parchment/68">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-card space-y-4">
    <p class="eyebrow">Direction</p>
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="premium-card">
        <h3 class="font-display text-3xl text-parchment">Collabs without same-room dependency</h3>
        <p class="mt-2 text-sm text-parchment/68">
          Think audience-sharing, creator features, relays, and themed crossover structure. Not just two models squeezing into one room.
        </p>
      </div>
      <div class="premium-card">
        <h3 class="font-display text-3xl text-parchment">Recurring fan relationships</h3>
        <p class="mt-2 text-sm text-parchment/68">
          More VIP logic, more event rhythm, more owned audience. Less dependence on starting from zero every time you go live.
        </p>
      </div>
    </div>
  </section>

  <TrustRulesBlock title="Trust + control stays with the model" />

  <section class="content-card space-y-4">
    <h2 class="font-display text-4xl font-light text-parchment">Get in before April 2026.</h2>
    <p class="text-sm text-parchment/72">
      If you are active now, want founding access, or want guided planning before the line opens, apply now. The page clearly reflects a
      launch in April 2026, not a fully productized offer today.
    </p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/apply/?interest=founding&audience=active')}>Apply for Founding Access</a>
      <a class="btn btn-secondary" href={withBase('/how-it-works/')}>See both paths</a>
    </div>
  </section>
</MainLayout>
