---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/growth';
---

<MainLayout title="Growth | NaughtyCamSpot" description="Premium growth lane for active cam models.">
  <SEO slot="head" title="Growth | NaughtyCamSpot" description="Premium growth lane for active cam models." path={canonicalPath} />

  <section class="hero-shell hero-split parallax-veil space-y-4">
    <div class="hero-content">
      <p class="eyebrow">Growth lane</p>
      <h1 class="hero-title">Premium growth systems for <em>active cam models</em>.</h1>
      <p class="hero-sub">Structured growth across traffic, room conversion, VIP retention, and passive income. This page is for active operators, not beginner account setup.</p>
    </div>
    <div class="hero-media">
      <img src="/images/home-hero-1280.jpg" alt="Luxury editorial growth visual" loading="lazy" decoding="async" />
    </div>
  </section>

  <section class="content-card space-y-5">
    <p class="eyebrow">Who this is for</p>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <p class="bg-midnight p-5 text-sm text-parchment/75">Active models with existing accounts that need stronger revenue systems.</p>
      <p class="bg-obsidian p-5 text-sm text-parchment/75">Creators ready for weekly structure, testing cadence, and retention workflows.</p>
      <p class="bg-midnight p-5 text-sm text-parchment/75">Operators who want control-first growth without giving up ownership.</p>
    </div>
  </section>

  <section class="space-y-6">
    <div class="section-intro">
      <p class="eyebrow">Package ladder (placeholder)</p>
      <h2 class="section-heading">Growth packages presented with premium editorial cadence.</h2>
      <p class="text-sm text-parchment/65">Growth ladder only. Guided launch and Start Right remain outside this structure.</p>
    </div>
    <div class="grid gap-px bg-gold/20 md:grid-cols-3">
      <article class="premium-card"><p class="eyebrow">Tier I</p><h3 class="font-display text-4xl text-parchment">[Growth Package 1]</h3><p class="mt-2 text-sm text-parchment/68">Foundation sprint support placeholder.</p></article>
      <article class="premium-card bg-[#100d07]"><p class="eyebrow">Tier II</p><h3 class="font-display text-4xl text-parchment">[Growth Package 2]</h3><p class="mt-2 text-sm text-parchment/68">Scaling + retention placeholder.</p></article>
      <article class="premium-card"><p class="eyebrow">Tier III</p><h3 class="font-display text-4xl text-parchment">[Growth Package 3]</h3><p class="mt-2 text-sm text-parchment/68">Premium strategic execution placeholder.</p></article>
    </div>
  </section>

  <section class="content-card space-y-4">
    <p class="eyebrow">Add-ons + FAQ posture</p>
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="premium-card"><h3 class="font-display text-3xl text-parchment">Add-ons (placeholder)</h3><p class="mt-2 text-sm text-parchment/68">Optional sprint add-ons are scoped case-by-case and documented without hype claims.</p></div>
      <div class="premium-card"><h3 class="font-display text-3xl text-parchment">FAQ rhythm</h3><p class="mt-2 text-sm text-parchment/68">Questions focus on scope, control boundaries, and practical timelines.</p></div>
    </div>
  </section>

  <TrustRulesBlock title="Trust + control stays with the model" />

  <section class="content-card space-y-4">
    <h2 class="font-display text-4xl font-light text-parchment">Ready for growth execution?</h2>
    <p class="text-sm text-parchment/72">Apply if you already run live and want structured growth support without surrendering ownership.</p>
    <div class="flex flex-wrap gap-3">
      <a class="btn btn-primary" href={withBase('/apply/?audience=active')}>Apply for Growth</a>
      <a class="btn btn-secondary" href={withBase('/how-it-works/')}>See both paths</a>
    </div>
  </section>
</MainLayout>
