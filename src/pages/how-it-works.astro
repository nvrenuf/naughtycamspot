---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/how-it-works';
---

<MainLayout title="How It Works | NaughtyCamSpot" description="How the Growth lane and guided launch lane work.">
  <SEO slot="head" title="How It Works | NaughtyCamSpot" description="How the Growth lane and guided launch lane work." path={canonicalPath} />

  <section class="hero-shell parallax-veil space-y-4">
    <p class="hero-tagline">How It Works</p>
    <h1 class="font-display text-4xl text-white sm:text-5xl">Two paths, one control-first standard.</h1>
    <p class="max-w-3xl text-white/75">NaughtyCamSpot has two distinct lanes: a premium Growth lane for active cam models and a guided launch lane for new models using Professional Onboarding Tools.</p>
  </section>

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Growth workflow</h2>
    <ol class="list-decimal space-y-2 pl-5 text-sm text-white/75">
      <li>Apply and select the active-model path.</li>
      <li>Get a growth audit and four-pillar opportunity map.</li>
      <li>Enter the package ladder with placeholder-defined execution blocks.</li>
      <li>Run weekly optimization cycles and controlled iteration.</li>
    </ol>
  </section>

  <section class="content-card space-y-4">
    <h2 class="font-display text-3xl text-white">Launch workflow</h2>
    <ol class="list-decimal space-y-2 pl-5 text-sm text-white/75">
      <li>Apply</li>
      <li>Use Professional Onboarding Tools</li>
      <li>Choose platform</li>
      <li>Signup through routed path</li>
      <li>Unlock Start Right</li>
    </ol>
    <p class="text-sm text-white/65">Start Right is post-signup only. It does not sit in the public growth ladder and is unlocked only after routed signup completion.</p>
    <a class="btn btn-secondary" href={withBase('/platforms/')}>Go to Platforms</a>
  </section>

  <TrustRulesBlock title="Trust reinforcement" />
</MainLayout>
