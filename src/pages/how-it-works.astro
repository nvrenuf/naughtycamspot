---
import MainLayout from '../layouts/MainLayout.astro';
import SEO from '../components/SEO.astro';
import TrustRulesBlock from '../components/TrustRulesBlock.astro';
import { withBase } from '../utils/links';

const canonicalPath = '/how-it-works';
---

<MainLayout title="How It Works | NaughtyCamSpot" description="How the Growth lane and guided launch lane work.">
  <SEO slot="head" title="How It Works | NaughtyCamSpot" description="How the Growth lane and guided launch lane work." path={canonicalPath} />

  <section class="content-card section-intro">
    <p class="eyebrow">How it works</p>
    <h1 class="section-heading">Two paths, one <em class="not-italic text-gold">control-first</em> standard.</h1>
    <p class="text-sm text-parchment/70">NCS runs two clear lanes: Growth for active models and guided launch through Professional Onboarding Tools for new models.</p>
  </section>

  <section class="grid gap-px bg-gold/20 md:grid-cols-2">
    <article class="split-choice"><p class="eyebrow">Path A</p><h2 class="font-display text-4xl text-parchment">Growth lane</h2><p class="mt-2 text-sm text-parchment/68">For active models ready for structured execution.</p></article>
    <article class="split-choice"><p class="eyebrow">Path B</p><h2 class="font-display text-4xl text-parchment">Guided launch</h2><p class="mt-2 text-sm text-parchment/68">For new models needing onboarding tools before go-live.</p></article>
  </section>

  <section class="space-y-6">
    <div class="section-intro">
      <p class="eyebrow">Sequence</p>
      <h2 class="section-heading">Growth workflow</h2>
    </div>
    <div class="grid gap-px bg-gold/15 md:grid-cols-2">
      {['Apply and select active-model path','Receive four-pillar growth audit and opportunity map','Enter package ladder with scoped execution blocks','Run weekly optimization cycles and controlled iteration'].map((step, index) => (
        <article class="pill-item"><p class="font-display text-5xl text-gold/25">0{index + 1}</p><p class="mt-2 text-sm text-parchment/72">{step}</p></article>
      ))}
    </div>
  </section>

  <section class="content-card space-y-4">
    <p class="eyebrow">Launch workflow</p>
    <ol class="space-y-2 text-sm text-parchment/75">
      <li>1. Apply.</li>
      <li>2. Use Professional Onboarding Tools.</li>
      <li>3. Choose platform fit.</li>
      <li>4. Signup through routed path.</li>
      <li>5. Unlock Start Right.</li>
    </ol>
    <p class="text-sm text-parchment/62">Start Right is post-signup only and is not part of the public growth package ladder.</p>
    <a class="btn btn-secondary" href={withBase('/platforms/')}>Go to Platforms</a>
  </section>

  <TrustRulesBlock title="Trust reinforcement" />
</MainLayout>
