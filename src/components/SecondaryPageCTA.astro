---
import LinkCTA from './LinkCTA.astro';
import { PRIMARY_CTA } from '../data/copy';
import { withBase } from '../utils/links';

type SecondaryLink = {
  href: string;
  label: string;
};

const {
  title = 'Ready to move?',
  description = 'Apply once and get the next step that fits you.',
  secondaryLinks = []
} = Astro.props as {
  title?: string;
  description?: string;
  secondaryLinks?: SecondaryLink[];
};
---

<section class="content-card flex flex-col gap-4 sm:gap-5">
  <div class="space-y-2">
    <p class="text-xs uppercase tracking-[0.3em] text-rose-petal/70">Next step</p>
    <h2 class="font-display text-3xl text-white">{title}</h2>
    <p class="max-w-2xl text-sm text-white/75">{description}</p>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <LinkCTA
      class="border border-rose-gold/70 bg-rose-gold px-6 py-3 text-sm text-midnight shadow-glow"
      pagesHref={PRIMARY_CTA.pagesHref}
      prodHref={PRIMARY_CTA.prodHref}
      label={PRIMARY_CTA.label}
    />
    {secondaryLinks.map((link) => (
      <a
        class="inline-flex items-center justify-center rounded-full border border-white/20 bg-transparent px-6 py-3 text-xs uppercase tracking-[0.3em] text-white transition hover:border-white/40 hover:bg-white/5"
        href={withBase(link.href)}
      >
        {link.label}
      </a>
    ))}
  </div>
</section>
