---
import { promoLaunch } from '../data/promoLaunch';

const {
  title = promoLaunch.statusTag,
  body = promoLaunch.shortNotice
} = Astro.props as {
  title?: string;
  body?: string;
};
---

<section class="content-card space-y-3 border border-gold/25 bg-obsidian/90">
  <p class="eyebrow">Launch Status</p>
  <div class="flex flex-wrap items-center gap-3">
    <span class="rounded-full border border-gold/35 px-3 py-1 text-xs uppercase tracking-[0.18em] text-gold/90">{promoLaunch.statusTag}</span>
    <h2 class="font-display text-3xl font-light text-parchment sm:text-4xl">{title}</h2>
  </div>
  <p class="max-w-3xl text-sm text-parchment/72">{body}</p>
</section>
