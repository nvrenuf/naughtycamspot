---
const { title = 'Trust Rules', compact = false } = Astro.props as {
  title?: string;
  compact?: boolean;
};

const items = [
  'No passwords',
  'No exclusivity',
  'Model owns accounts and content',
  'Cancel anytime',
  'No fake official partner claims',
  'No spam tactics',
  'No misleading earnings promises'
] as const;
---

<section class:list={['content-card space-y-4', compact && 'space-y-3']}>
  <div class="space-y-2">
    <p class="text-xs uppercase tracking-[0.32em] text-rose-petal/70">Trust + Control</p>
    <h2 class="font-display text-2xl text-white sm:text-3xl">{title}</h2>
    <p class="max-w-2xl text-sm text-white/75">These are hard rules across both lanes.</p>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    {items.map((item) => (
      <p class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white/80">{item}</p>
    ))}
  </div>
</section>
